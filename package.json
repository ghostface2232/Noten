    "@tiptap/extension-task-list": "^3.24.0",
    "@tiptap/extension-text-align": "^3.24.0",
    "@tiptap/extension-typography": "^3.24.0",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/markdown": "^3.24.0",
    "@tiptap/pm": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@tiptap/suggestion": "^3.24.0",
    "lowlight": "^3.3.0",
