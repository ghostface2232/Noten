{
  "name": "noten",
  "private": true,
  "version": "0.2.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare-helper": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-helper.ps1",
    "prepare-helper:release": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-helper.ps1 -Release",
