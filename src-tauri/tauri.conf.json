{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noten",
  "version": "0.1.0",
  "identifier": "com.noten.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Noten",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 620,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3QTE1MTU4REE0MTc3NUEKUldSYWQwSGFXRkdoeDZBL1h2Y2JYQ2VQU3BLVm8xeDNFb05ybGs5dmNzMTM2VVRaRFN4OVRJdGwK",
      "endpoints": [
        "https://github.com/ghostface2232/Noten/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
